# === Consorcio Canalero Backend — Environment Variables ===

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql://consorcio:consorcio_dev@localhost:5432/consorcio
DATABASE_ECHO=false

# JWT Secret — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE-ME-IN-PRODUCTION

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Google OAuth (optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Google Earth Engine (optional)
GEE_KEY_FILE_PATH=
GEE_SERVICE_ACCOUNT_KEY=
GEE_PROJECT_ID=cc10demayo

# Legacy Supabase (required during migration — set dummy values if not using)
SUPABASE_URL=http://localhost:54321
SUPABASE_KEY=dummy-key-for-migration
SUPABASE_JWT_SECRET=dummy-jwt-secret

# Debug
DEBUG=true
