# ==============================================
# Consorcio Canalero Backend — Environment Variables
# Copy to .env and fill in your values
# ==============================================

# --- Database (PostgreSQL + PostGIS) ---
DATABASE_URL=postgresql://consorcio:consorcio_dev@localhost:5432/consorcio
DATABASE_ECHO=false

# --- Auth (JWT + Google OAuth) ---
JWT_SECRET=change-me-to-a-random-64-char-string
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Google Earth Engine ---
GEE_KEY_FILE_PATH=/app/credentials/gee-service-account.json
GEE_SERVICE_ACCOUNT_KEY=
GEE_PROJECT_ID=cc10demayo

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- App ---
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173
API_PREFIX=/api/v1

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# --- Contact ---
CONTACT_PHONE=+54 353 4000000
CONTACT_EMAIL=contacto@consorcio10demayo.gob.ar

# --- Legacy Supabase (to be removed) ---
SUPABASE_URL=https://placeholder.supabase.co
SUPABASE_KEY=placeholder
