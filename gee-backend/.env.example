# ==============================================
# Consorcio Canalero Backend — Environment Variables
# Copy to .env and fill in your values
# ==============================================

# --- Database (PostgreSQL + PostGIS) ---
DATABASE_URL=postgresql://consorcio:consorcio_dev@localhost:5432/consorcio
DATABASE_ECHO=false

# --- Auth (JWT + Google OAuth) ---
JWT_SECRET=change-me-to-a-random-64-char-string
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Google Earth Engine ---
GEE_KEY_FILE_PATH=/app/credentials/gee-service-account.json
GEE_SERVICE_ACCOUNT_KEY=
GEE_PROJECT_ID=cc10demayo

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- App ---
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173
API_PREFIX=/api/v1

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# --- Contact ---
CONTACT_PHONE=+54 353 4000000
CONTACT_EMAIL=contacto@consorcio10demayo.gob.ar

# --- Legacy Supabase (to be removed) ---
SUPABASE_URL=https://placeholder.supabase.co
SUPABASE_KEY=placeholder

# --- Martin tile server (Vector Tiles) ---
# MARTIN_INTERNAL_URL: Internal Docker network address the backend uses to fetch
#   the Martin catalog and build tile proxies. Must be reachable within the Docker
#   network — do not change unless you rename the Martin service.
MARTIN_INTERNAL_URL=http://martin:3000
# MARTIN_PUBLIC_URL: Public-facing base URL rewritten into tile URL templates
#   returned by GET /api/v2/public/layers/catalog. External consumers (QGIS,
#   browsers) use this URL to fetch actual MVT tiles directly from Martin.
#   Example: https://tiles.consorcio10demayo.gob.ar
#   Leave empty in local dev (Martin accessible at http://localhost:3000).
MARTIN_PUBLIC_URL=
