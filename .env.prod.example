# ====================================================
# Consorcio Canalero - Variables de Produccion
# ====================================================
# Frontend: Cloudflare Pages (vars se configuran en el dashboard de CF, no aca)
# Backend + geo-worker + Martin: Docker en Hetzner
#
# Copiá este archivo a /home/javier/stacks/consorcio/.env
# y completá los valores reales antes de levantar el stack.
# NUNCA comitees el .env con valores reales.
#
# Variables para Cloudflare Pages (configurar en CF dashboard):
#   VITE_API_URL    = https://api.consorcio.DOMINIO
#   VITE_MARTIN_URL = https://tiles.consorcio.DOMINIO
# ====================================================

# --- Imagenes Docker (GHCR) ---
BACKEND_IMAGE=ghcr.io/jnzader/consorcio-canalero/backend:latest
GEO_WORKER_IMAGE=ghcr.io/jnzader/consorcio-canalero/geo-worker:latest

# --- Base de datos (PostgreSQL compartido = shared-postgres) ---
# El nombre de la DB en produccion es consorcio_canalero (distinto al dev = consorcio)
DATABASE_URL=postgresql+asyncpg://consorcio:CAMBIAR_PASSWORD_CONSORCIO@shared-postgres:5432/consorcio_canalero

# --- Redis (compartido = shared-redis, db0 para consorcio) ---
REDIS_URL=redis://:CAMBIAR_PASSWORD_REDIS@shared-redis:6379/0

# --- JWT ---
JWT_SECRET=CAMBIAR_CON_openssl_rand_hex_32

# --- Google OAuth (opcional) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Google Earth Engine (opcional) ---
GEE_PROJECT_ID=cc10demayo
GEE_SERVICE_ACCOUNT_KEY=

# --- CORS (Cloudflare Pages acepta requests desde este origen) ---
# Incluir tanto el dominio propio como el .pages.dev por si acaso
CORS_ORIGINS=https://consorcio.DOMINIO,https://consorcio-canalero.pages.dev

# --- Martin (URLs para el backend) ---
MARTIN_INTERNAL_URL=http://consorcio-martin:3000
MARTIN_PUBLIC_URL=https://tiles.consorcio.DOMINIO

# --- Geo Worker (URL interna) ---
GEO_WORKER_TILE_URL=http://consorcio-geo-worker:8001

# --- App ---
DEBUG=false
ENABLE_DOCS=false
FRONTEND_URL=https://consorcio.DOMINIO
API_BASE_URL=https://api.consorcio.DOMINIO

# --- Martin DB URL (sin +asyncpg, para el martin-config.yaml) ---
MARTIN_DB_URL=postgresql://consorcio:CAMBIAR_PASSWORD_CONSORCIO@shared-postgres:5432/consorcio_canalero
