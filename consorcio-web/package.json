{
  "name": "consorcio-web",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "postinstall": "patch-package",
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "biome format --write ./src",
    "format:check": "biome format ./src",
    "check": "biome check ./src",
    "check:fix": "biome check --write ./src",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test -c tests/accessibility/playwright.config.ts",
    "test:e2e:local": "playwright test -c tests/e2e/playwright.local.config.ts",
    "test:a11y": "playwright test -c tests/accessibility/playwright.config.ts",
    "test:smoke": "vitest run tests/unit/api.test.ts",
    "mutation:run": "stryker run",
    "generate:types": "openapi-typescript http://localhost:8000/openapi.json -o ./src/types/schema.d.ts",
    "gen:pmtiles": "tippecanoe -o public/data/suelos_cu.pmtiles -z12 -Z6 --force --layer=suelos_cu public/data/suelos_cu.geojson && tippecanoe -o public/data/catastro_rural_cu.pmtiles -z14 -Z8 --force --layer=catastro_rural_cu public/data/catastro_rural_cu.geojson && tippecanoe -o public/waterways/rio_tercero.pmtiles -z14 -Z8 --force --layer=rio_tercero public/waterways/rio_tercero.geojson && tippecanoe -o public/waterways/arroyo_algodon.pmtiles -z14 -Z8 --force --layer=arroyo_algodon public/waterways/arroyo_algodon.geojson && tippecanoe -o public/waterways/canal_desviador.pmtiles -z14 -Z8 --force --layer=canal_desviador public/waterways/canal_desviador.geojson && tippecanoe -o public/waterways/canal_litin_tortugas.pmtiles -z14 -Z8 --force --layer=canal_litin_tortugas public/waterways/canal_litin_tortugas.geojson && tippecanoe -o public/waterways/arroyo_las_mojarras.pmtiles -z14 -Z8 --force --layer=arroyo_las_mojarras public/waterways/arroyo_las_mojarras.geojson"
  },
  "dependencies": {
    "@fontsource/dm-serif-display": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@mantine/charts": "^8.3.14",
    "@mantine/core": "^8.3.14",
    "@mantine/dates": "^8.3.14",
    "@mantine/dropzone": "^8.3.14",
    "@mantine/form": "^8.3.14",
    "@mantine/hooks": "^8.3.14",
    "@mantine/notifications": "^8.3.14",
    "@mapbox/mapbox-gl-draw": "^1.5.1",
    "@tabler/icons-react": "^3.36.1",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.147.0",
    "dayjs": "^1.11.19",
    "maplibre-gl": "^4.7.1",
    "pmtiles": "^4.4.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-helmet-async": "^2.0.5",
    "recharts": "^3.7.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.48.0",
    "@stryker-mutator/core": "^8.5.0",
    "@stryker-mutator/vitest-runner": "^8.5.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/mapbox__mapbox-gl-draw": "^1.4.9",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "happy-dom": "^20.1.0",
    "openapi-typescript": "^7.10.1",
    "patch-package": "^8.0.1",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.16"
  }
}
