{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker-js/master/packages/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "mutate": [
    "src/lib/formatters.ts",
    "src/lib/validators.ts",
    "src/lib/calculations.ts",
    "src/lib/constants.ts",
    "src/lib/object-helpers.ts"
  ],
  "testMatch": [
    "tests/unit/lib/utils/formatters.test.ts",
    "tests/unit/lib/utils/validators.test.ts",
    "tests/unit/lib/utils/calculations.test.ts",
    "tests/unit/lib/utils/constants.test.ts",
    "tests/unit/lib/utils/object-helpers.test.ts"
  ],
  "reporters": ["html", "json", "clear-text"],
  "htmlReporter": {
    "fileName": "reports/phase-1-mutation/index.html"
  },
  "timeoutMS": 5000,
  "thresholds": {
    "high": 85,
    "low": 80,
    "break": 80
  },
  "concurrency": 4,
  "allowEmpty": false,
  "cleanTempDir": true
}
