# Cloudflare Pages headers. Vite copies this file to dist/_headers at build time.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://tile.openstreetmap.org https://*.tile.openstreetmap.org https://*.tile.opentopomap.org https://server.arcgisonline.com https://earthengine.googleapis.com https://cc10demayo-api.javierzader.com https://*.javierzader.com https://*.consorcio10demayo.com.ar https://consorcio10demayo.com.ar; font-src 'self' data:; connect-src 'self' https://consorcio-canalero.pages.dev https://*.pages.dev https://cc10demayo-api.javierzader.com https://*.javierzader.com https://*.consorcio10demayo.com.ar https://consorcio10demayo.com.ar https://earthengine.googleapis.com https://server.arcgisonline.com https://tile.openstreetmap.org https://*.tile.openstreetmap.org https://*.tile.opentopomap.org https://api.mapbox.com; worker-src 'self' blob:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/data/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=43200

/capas/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=43200

/waterways/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=43200

/favicon.ico
  Cache-Control: public, max-age=604800

/manifest.webmanifest
  Cache-Control: public, max-age=86400
  Content-Type: application/manifest+json

/registerSW.js
  Cache-Control: no-cache

/sw.js
  Cache-Control: no-cache

/workbox-*.js
  Cache-Control: no-cache
