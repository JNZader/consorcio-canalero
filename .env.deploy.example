# ===========================================
# Consorcio Canalero — Hetzner Production
# ===========================================
# cp .env.hetzner.example .env
# Editar TODOS los valores marcados CAMBIAR_*

# --- Database ---
DB_USER=consorcio
DB_PASSWORD=CAMBIAR_DB_PASSWORD
DATABASE_URL=postgresql://consorcio:CAMBIAR_DB_PASSWORD@postgres:5432/consorcio

# --- Redis ---
REDIS_PASSWORD=CAMBIAR_REDIS_PASSWORD
REDIS_URL=redis://:CAMBIAR_REDIS_PASSWORD@redis:6379/0

# --- Auth ---
JWT_SECRET=CAMBIAR_JWT_SECRET
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Google Earth Engine ---
# Opcion A: path al archivo JSON de service account
GEE_KEY_FILE_PATH=/app/credentials/gee-sa-key.json
# Opcion B: contenido inline del JSON (si no usas archivo)
# GEE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
GEE_PROJECT_ID=cc10demayo

# --- CORS + URLs ---
CORS_ORIGINS=https://consorcio-canalero.pages.dev,https://cc10demayo.javierzader.com
FRONTEND_URL=https://consorcio-canalero.pages.dev
API_BASE_URL=https://cc10demayo-api.javierzader.com

# --- Geo Worker ---
GEO_WORKER_TILE_URL=http://consorcio-geo-worker:8001

# --- Martin ---
MARTIN_INTERNAL_URL=http://consorcio-martin:3000
MARTIN_PUBLIC_URL=https://cc10demayo-api.javierzader.com/tiles

# --- App ---
ENVIRONMENT=production
DEBUG=false
ENABLE_DOCS=false
