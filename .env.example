# ===========================================
# Stack-level environment variables for docker-compose
# ===========================================
#
# Docker Compose auto-loads a file named `.env` from the directory it runs
# in (the repo root). Values defined here are interpolated into
# `docker-compose.yml` via `${VAR:-default}` fallbacks.
#
# In production:
#   cp .env.example .env
#   # edit .env with real credentials (do NOT commit it — .env is gitignored)
#
# In development:
#   The `${VAR:-default}` fallbacks in docker-compose.yml make this file
#   optional — the compose will boot with dev-safe defaults if `.env` is
#   absent. Only create a `.env` locally if you want to override something.
#
# Per-service `.env` files (e.g. gee-backend/.env, consorcio-web/.env) are
# still used for app-level config. This root-level file is ONLY for
# stack-wide values consumed by docker-compose itself.
# ===========================================

# -------------------------------------------
# PostgreSQL (consumed by the `postgres` service)
# -------------------------------------------
# Database name, user, and password for the Postgres container.
# If you change these, make sure DATABASE_URL below matches.
POSTGRES_DB=consorcio
POSTGRES_USER=consorcio
POSTGRES_PASSWORD=

# -------------------------------------------
# Backend / workers connection strings
# -------------------------------------------
# Connection string used by backend, worker, and geo-worker services.
# Example: postgresql://consorcio:CHANGE_ME@postgres:5432/consorcio
DATABASE_URL=

# Redis broker/cache URL. Include the password when running in prod.
# WARNING: If the Redis container is started with --requirepass, this URL MUST
# include the password or all services (backend, worker, geo-worker) will fall
# back to in-memory caching and the Celery worker will report unhealthy.
# Example with password: redis://:CHANGE_ME@redis:6379/0
# Example without password (dev): redis://redis:6379/0
REDIS_URL=

# -------------------------------------------
# Backend runtime flags
# -------------------------------------------
# Deployment environment. Accepted: development | production
# Controls log verbosity, error detail exposure, and related runtime flags.
ENVIRONMENT=

# Enable verbose debug logging and extra error context. Accepted: true | false
DEBUG=

# When true, the rate-limiter middleware is skipped. Prod should always be false.
RATE_LIMIT_DISABLED=

# -------------------------------------------
# Martin MVT (vector tile) endpoints
# -------------------------------------------
# Internal hostname used by the backend to reach the Martin MVT service.
# In prod, typically http://consorcio-martin:3000. Empty = fall back to dev default.
MARTIN_INTERNAL_URL=

# Public URL where Martin tiles are served to browsers (via the reverse proxy).
# In prod, typically https://cc10demayo-api.example.com/tiles. Empty = no public tiles.
MARTIN_PUBLIC_URL=

# -------------------------------------------
# CORS
# -------------------------------------------
# Comma-separated list of allowed CORS origins for the API.
# In prod, typically https://<frontend-domain>,https://<admin-domain>.
CORS_ORIGINS=
